APP_ENV=development
APP_SECRET_KEY=replace-with-strong-secret
DEBUG=false
PROJECT_NAME=Code Review Agent
VERSION=1.0.0
API_PREFIX=/api/v1

# Required for PR analysis endpoints
GITHUB_TOKEN=replace-with-github-token
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_CHAT_MODEL=gemini-3.1-pro-preview
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Infrastructure
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/code_review
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_CLIENT_URL=redis://redis:6379/0
